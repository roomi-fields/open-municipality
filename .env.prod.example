# ─── Docker Compose Prod ─────────────────────────────────────────────
# Copier en .env.prod puis éditer. Ne JAMAIS commiter .env.prod.

# === Domaine public ===
SITE_URL=https://plateformecitoyennelisloise.fr
DIRECTUS_PUBLIC_URL=https://admin.plateformecitoyennelisloise.fr
# URL Directus visible depuis le navigateur (composants React clients)
PUBLIC_DIRECTUS_URL=https://admin.plateformecitoyennelisloise.fr

# === PostgreSQL (Directus) ===
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Directus ===
DIRECTUS_SECRET=CHANGE_ME_RANDOM_64_HEX
ADMIN_EMAIL=admin@plateformecitoyennelisloise.fr
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === JWT session citoyens ===
JWT_SECRET=CHANGE_ME_RANDOM_64_HEX

# === Brevo (emails transactionnels + SMTP pour Plausible) ===
BREVO_API_KEY=xkeysib-xxxxxxxx
EMAIL_FROM_ADDR=contact@plateformecitoyennelisloise.fr
BREVO_SMTP_USER=login-brevo-smtp
BREVO_SMTP_PASSWORD=mot-de-passe-smtp

# === Claude API (parsing PV + OJ) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Plausible (analytics) ===
PLAUSIBLE_BASE_URL=https://stats.plateformecitoyennelisloise.fr
PLAUSIBLE_POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# openssl rand -base64 48
PLAUSIBLE_SECRET_KEY_BASE=CHANGE_ME_RANDOM_64_CHARS

# Script tag Plausible injecté dans les pages (domaine du site tracké)
PLAUSIBLE_DOMAIN=plateformecitoyennelisloise.fr
PLAUSIBLE_SRC=https://stats.plateformecitoyennelisloise.fr/js/script.js
