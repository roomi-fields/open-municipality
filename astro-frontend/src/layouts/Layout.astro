---
import HeaderMenu from '../components/HeaderMenu.tsx'
import CollectiviteSelector from '../components/CollectiviteSelector.tsx'

interface Props {
  title?: string
}
const { title = 'Plateforme Citoyenne Lisloise' } = Astro.props

const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN || ''
const plausibleSrc = import.meta.env.PLAUSIBLE_SRC || 'https://plausible.io/js/script.js'
---

<html lang="fr">
  <head>
    <style is:global>@import "tailwindcss";</style>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Suivez les décisions du conseil municipal, votez, commentez, proposez." />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    {plausibleDomain && (
      <script is:inline defer data-domain={plausibleDomain} src={plausibleSrc}></script>
    )}
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <header class="border-b border-gray-200 bg-white">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="text-xl font-bold text-green-800">
          Plateforme Citoyenne Lisloise
        </a>
        <div class="flex items-center gap-6 text-sm font-medium">
          <div class="group relative">
            <button
              type="button"
              class="flex items-center gap-1 hover:text-green-700 focus:outline-none focus:text-green-700"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Les conseils
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                <path d="M2 4l4 4 4-4z" />
              </svg>
            </button>
            <div
              class="invisible absolute left-0 top-full z-20 mt-1 w-56 rounded-md border border-gray-200 bg-white py-2 opacity-0 shadow-lg transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              role="menu"
            >
              <a href="/seances" class="block px-4 py-2 hover:bg-green-50 hover:text-green-700" role="menuitem">Séances</a>
              <a href="/deliberations" class="block px-4 py-2 hover:bg-green-50 hover:text-green-700" role="menuitem">Délibérations</a>
              <a href="/elus" class="block px-4 py-2 hover:bg-green-50 hover:text-green-700" role="menuitem">Élus</a>
              <a href="/engagements" class="block px-4 py-2 hover:bg-green-50 hover:text-green-700" role="menuitem">Programme</a>
            </div>
          </div>
          <a href="/blog" class="hover:text-green-700">Blog</a>
          <HeaderMenu client:load />
        </div>
      </nav>
    </header>
    <CollectiviteSelector client:load />
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-500">
      <p>Plateforme Citoyenne Lisloise — Outil open source de transparence municipale</p>
      <p class="mt-1">Les résumés sont une vulgarisation citoyenne. Le texte officiel fait foi.</p>
      <p class="mt-1">Données publiques · Aucun tracking</p>
    </footer>
  </body>
</html>

