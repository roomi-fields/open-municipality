---
import Layout from '../../layouts/Layout.astro'
import { fetchItems, getSeanceIds } from '../../lib/directus'

const collectivite = Astro.url.searchParams.get('collectivite') || ''

const delibParams: Record<string, string> = {
  'filter[statut][_eq]': 'publie',
  sort: '-id',
  limit: '50',
}
if (collectivite) {
  const seanceIds = await getSeanceIds(collectivite)
  if (seanceIds.length > 0) {
    delibParams['filter[seance][_in]'] = seanceIds.join(',')
  } else {
    delibParams['filter[seance][_eq]'] = '-1'
  }
}
const deliberations = await fetchItems('deliberations', delibParams)
const themes = await fetchItems('themes', { sort: 'nom', limit: '50' })
const themeMap: Record<number, any> = {}
for (const t of themes) {
  themeMap[t.id] = t
}
---

<Layout title="Deliberations">
  <h1 class="text-3xl font-bold mb-6">Deliberations</h1>

  <div class="space-y-4">
    {deliberations.map((d) => (
      <a href={`/deliberations/${d.id}`} class="block rounded-lg border border-gray-200 p-5 hover:border-green-300 hover:bg-green-50 transition-colors">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-mono text-gray-400">{d.numero}</span>
              {d.theme && themeMap[d.theme] && (
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                  {themeMap[d.theme].nom}
                </span>
              )}
            </div>
            <h2 class="font-semibold text-green-800">{d.titre}</h2>
            <p class="text-sm text-gray-600 mt-1">{d.resume_ia?.substring(0, 150)}</p>
          </div>
        </div>
        <div class="mt-3 flex gap-4 text-sm">
          <span class="text-green-600 font-medium">Pour: {d.vote_pour}</span>
          <span class="text-red-600">Contre: {d.vote_contre}</span>
          <span class="text-gray-400">Abstention: {d.vote_abstention}</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
