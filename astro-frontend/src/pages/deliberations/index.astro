---
import Layout from '../../layouts/Layout.astro'
import { fetchItems, getSeanceIds } from '../../lib/directus'

const collectivite = Astro.url.searchParams.get('collectivite') || ''

let seanceFilter: string[] | null = null
if (collectivite) {
  const ids = await getSeanceIds(collectivite)
  seanceFilter = ids.length > 0 ? ids.map(String) : ['-1']
}

const baseParams = (statut: string): Record<string, string> => {
  const p: Record<string, string> = {
    'filter[statut][_eq]': statut,
    sort: '-id',
    limit: '100',
    fields: 'id,numero,titre,resume_ia,statut,vote_pour,vote_contre,vote_abstention,theme,seance.date,seance.type',
  }
  if (seanceFilter) p['filter[seance][_in]'] = seanceFilter.join(',')
  return p
}

const aVenir = await fetchItems('deliberations', baseParams('a_venir'))
const publiees = await fetchItems('deliberations', baseParams('publie'))

const themes = await fetchItems('themes', { sort: 'nom', limit: '50' })
const themeMap: Record<number, any> = {}
for (const t of themes) themeMap[t.id] = t

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })
}
---

<Layout title="Délibérations — Plateforme Citoyenne Lisloise">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Délibérations</h1>
    <p class="mt-2 text-sm text-gray-500">
      Votez sur les points à venir, consultez les décisions déjà prises.
    </p>
  </div>

  {aVenir.length > 0 && (
    <section class="mb-10">
      <div class="mb-3 flex items-baseline gap-2">
        <h2 class="text-xl font-bold text-orange-700">À venir</h2>
        <span class="text-sm text-gray-400">{aVenir.length} point{aVenir.length > 1 ? 's' : ''} d'ordre du jour</span>
      </div>
      <div class="space-y-3">
        {aVenir.map((d: any) => (
          <a href={`/deliberations/${d.id}`} class="block rounded-lg border border-orange-200 bg-orange-50/30 p-4 hover:border-orange-400 hover:bg-orange-50 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <span class="text-xs font-mono text-gray-400">{d.numero}</span>
                  {d.seance?.date && <span class="text-xs text-gray-500">Séance du {formatDate(d.seance.date)}</span>}
                  <span class="rounded-full bg-orange-200 px-2 py-0.5 text-xs text-orange-900 font-semibold">Vote citoyen ouvert</span>
                </div>
                <h3 class="font-semibold text-gray-900">{d.titre}</h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <div class="mb-3 flex items-baseline gap-2">
      <h2 class="text-xl font-bold">Délibérations passées</h2>
      <span class="text-sm text-gray-400">{publiees.length}</span>
    </div>
    {publiees.length === 0 ? (
      <p class="text-sm text-gray-500">Aucune délibération publiée pour le moment.</p>
    ) : (
      <div class="space-y-3">
        {publiees.map((d: any) => (
          <a href={`/deliberations/${d.id}`} class="block rounded-lg border border-gray-200 p-4 hover:border-green-300 hover:bg-green-50 transition-colors">
            <div class="flex items-center gap-2 mb-1 flex-wrap text-xs">
              <span class="font-mono text-gray-400">{d.numero}</span>
              {d.seance?.type === 'conseil_communautaire' && <span class="rounded-full bg-blue-50 px-2 py-0.5 text-blue-700">CCGT</span>}
              {d.seance?.type === 'conseil_municipal' && <span class="rounded-full bg-green-50 px-2 py-0.5 text-green-700">CM</span>}
              {d.theme && themeMap[d.theme] && (
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-gray-600">{themeMap[d.theme].nom}</span>
              )}
            </div>
            <h3 class="font-semibold text-green-800">{d.titre}</h3>
            {d.resume_ia && <p class="text-sm text-gray-600 mt-1 line-clamp-2">{d.resume_ia}</p>}
            <div class="mt-2 flex gap-4 text-xs text-gray-500">
              <span class="text-green-600 font-medium">Pour {d.vote_pour}</span>
              <span class="text-red-600">Contre {d.vote_contre}</span>
              <span class="text-gray-400">Abst. {d.vote_abstention}</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
