---
import Layout from '../layouts/Layout.astro'
import { fetchItems } from '../lib/directus'

const petitions = await fetchItems('petitions', { sort: '-id', limit: '50', 'fields': '*,theme.*' })
---

<Layout title="Pétitions — Plateforme Citoyenne">
  <h1 class="text-3xl font-bold mb-6">Pétitions</h1>

  <div class="space-y-4">
    {petitions.map((p: any) => {
      const pct = Math.min(100, (p.nombre_signatures / p.seuil) * 100)
      return (
        <div class="rounded-lg border border-gray-200 p-5">
          <div class="flex items-start justify-between">
            <div>
              {p.theme && (
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600 mr-2">
                  {p.theme.icone} {p.theme.nom}
                </span>
              )}
              <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${
                p.statut === 'ouverte' ? 'bg-blue-100 text-blue-700' :
                p.statut === 'seuil_atteint' ? 'bg-green-100 text-green-700' :
                'bg-gray-100 text-gray-700'
              }`}>
                {p.statut === 'ouverte' ? 'Ouverte' :
                 p.statut === 'seuil_atteint' ? 'Seuil atteint' :
                 p.statut === 'transmise' ? 'Transmise' : 'Répondue'}
              </span>
            </div>
          </div>
          <h3 class="text-lg font-semibold mt-2">{p.titre}</h3>
          <p class="text-sm text-gray-600 mt-1">{p.description}</p>
          <div class="mt-3">
            <div class="h-3 w-full rounded-full bg-gray-100">
              <div class="h-3 rounded-full bg-blue-600 transition-all" style={`width: ${pct}%`}></div>
            </div>
            <p class="text-sm text-gray-500 mt-1">{p.nombre_signatures} / {p.seuil} signatures</p>
          </div>
          {p.reponse_conseil && (
            <div class="mt-3 rounded bg-green-50 p-3 text-sm text-green-800">
              <span class="font-medium">Réponse du conseil :</span> {p.reponse_conseil}
            </div>
          )}
        </div>
      )
    })}
  </div>
</Layout>
