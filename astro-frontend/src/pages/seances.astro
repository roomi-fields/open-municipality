---
import Layout from '../layouts/Layout.astro'
import { fetchItems } from '../lib/directus'
import { matchEngagements, type Engagement } from '../lib/match-oj-engagements'

const seances = await fetchItems('seances', {
  'filter[statut][_eq]': 'a_venir',
  sort: 'date',
  limit: '50',
  fields: 'id,date,type,collectivite,lieu,statut,ordre_jour_items',
})

const collectivites = await fetchItems('collectivites', { limit: '50', fields: 'id,nom,type' })
const collMap: Record<number, any> = {}
for (const c of collectivites) collMap[c.id] = c

// Charger les délibérations "à venir" matérialisées pour permettre de cliquer et voter
const delibsAVenir = await fetchItems('deliberations', {
  'filter[statut][_eq]': 'a_venir',
  limit: '500',
  fields: 'id,numero,titre,seance',
})
// Map : `${seanceId}-${ojNumero}` → delibId (extrait depuis numero "OJ-YYYY-MM-DD-NNN")
const delibByOJ: Record<string, number> = {}
for (const d of delibsAVenir) {
  const match = d.numero?.match(/^OJ-\d{4}-\d{2}-\d{2}-(\d+)$/)
  if (match) {
    const num = parseInt(match[1], 10)
    delibByOJ[`${d.seance}-${num}`] = d.id
  }
}

// Engagements de campagne pour matching OJ ↔ Programme
const engagements: Engagement[] = await fetchItems('engagements', {
  limit: '200',
  fields: 'id,description,statut',
})

const statutColor: Record<string, string> = {
  realise: 'bg-green-100 text-green-700',
  en_cours: 'bg-yellow-100 text-yellow-700',
  pas_commence: 'bg-gray-100 text-gray-600',
  abandonne: 'bg-red-100 text-red-700',
}
const statutLabel: Record<string, string> = {
  realise: 'Réalisé', en_cours: 'En cours', pas_commence: 'Pas commencé', abandonne: 'Abandonné',
}

interface OJItem { section: string; numero: number; titre: string }
function parseOJ(raw: any): OJItem[] {
  if (!raw) return []
  if (Array.isArray(raw)) return raw
  try { return JSON.parse(raw) } catch { return [] }
}

function groupBySection(items: OJItem[]): Record<string, OJItem[]> {
  const out: Record<string, OJItem[]> = {}
  for (const it of items) {
    if (!out[it.section]) out[it.section] = []
    out[it.section].push(it)
  }
  return out
}

const typeLabel: Record<string, string> = {
  conseil_municipal: 'Conseil municipal',
  conseil_communautaire: 'Conseil communautaire',
}

function formatDate(iso: string): string {
  const d = new Date(iso)
  return d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })
}
---

<Layout title="Prochains conseils — Plateforme Citoyenne">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Prochains conseils</h1>
    <p class="mt-2 text-sm text-gray-500">{seances.length} séance(s) programmée(s) avec leurs ordres du jour quand ils sont publiés.</p>
  </div>

  {seances.length === 0 ? (
    <p class="text-gray-500">Aucune séance à venir programmée.</p>
  ) : (
    <div class="space-y-6">
      {seances.map((s: any) => {
        const coll = collMap[s.collectivite]
        const oj = parseOJ(s.ordre_jour_items)
        const sections = groupBySection(oj)
        const isCM = s.type === 'conseil_municipal'
        return (
          <article class={`rounded-lg border-l-4 ${isCM ? 'border-green-600' : 'border-blue-600'} border border-gray-200 p-5`}>
            <header class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h2 class="text-lg font-bold capitalize">{formatDate(s.date)}</h2>
                <div class="mt-1 flex flex-wrap gap-2 text-xs">
                  <span class={`rounded-full px-2 py-0.5 font-medium ${isCM ? 'bg-green-50 text-green-700' : 'bg-blue-50 text-blue-700'}`}>
                    {typeLabel[s.type] || s.type}
                  </span>
                  {coll && <span class="rounded-full bg-gray-100 px-2 py-0.5 text-gray-600">{coll.nom}</span>}
                  {s.lieu && <span class="text-gray-500">📍 {s.lieu}</span>}
                </div>
              </div>
              <span class="text-sm text-gray-400 shrink-0">{oj.length > 0 ? `${oj.length} points` : 'OJ à publier'}</span>
            </header>

            {oj.length > 0 ? (
              <div class="space-y-3">
                {Object.entries(sections).map(([section, items]) => (
                  <div>
                    <h3 class="text-sm font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">{section}</h3>
                    <ul class="space-y-2">
                      {items.map((it: OJItem) => {
                        const matches = matchEngagements(it.titre, engagements, { maxResults: 3 })
                        const delibId = delibByOJ[`${s.id}-${it.numero}`]
                        return (
                          <li class="flex items-start gap-2 text-sm">
                            <span class="text-gray-400 font-mono shrink-0 w-6 text-right">{it.numero}.</span>
                            <div class="flex-1">
                              {delibId ? (
                                <a href={`/deliberations/${delibId}`} class="hover:underline hover:text-green-700">
                                  {it.titre}
                                  <span class="ml-2 text-xs text-green-700 font-medium">→ Voter</span>
                                </a>
                              ) : (
                                <span>{it.titre}</span>
                              )}
                              {matches.length > 0 && (
                                <div class="mt-1 flex flex-wrap gap-1.5">
                                  <span class="text-xs text-gray-400">↳ Engagement{matches.length > 1 ? 's' : ''} lié{matches.length > 1 ? 's' : ''} :</span>
                                  {matches.map(({ engagement: e }) => (
                                    <a href="/engagements" title={e.description} class={`inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs hover:opacity-80 transition-opacity ${statutColor[e.statut || 'pas_commence']}`}>
                                      <span class="font-semibold">{statutLabel[e.statut || 'pas_commence']}</span>
                                      <span class="max-w-[30ch] truncate">— {e.description}</span>
                                    </a>
                                  ))}
                                </div>
                              )}
                            </div>
                          </li>
                        )
                      })}
                    </ul>
                  </div>
                ))}
              </div>
            ) : (
              <p class="text-sm text-gray-400 italic">L'ordre du jour sera publié quelques jours avant la séance.</p>
            )}
          </article>
        )
      })}
    </div>
  )}

  <p class="mt-8 text-xs text-gray-400">
    Sources : mairie-islejourdain.fr · ccgascognetoulousaine.com — Données publiques
  </p>
</Layout>
